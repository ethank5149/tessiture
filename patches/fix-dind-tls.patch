diff --git a/.forgejo/workflows/release.yml b/.forgejo/workflows/release.yml
index 8ab91e4..0eabc5f 100644
--- a/.forgejo/workflows/release.yml
+++ b/.forgejo/workflows/release.yml
@@ -241,6 +241,41 @@ jobs:
         shell: bash
         run: chmod +x deploy/scripts/build.sh deploy/scripts/deploy.sh
 
+      - name: Detect Docker connectivity (DinD TLS fallback)
+        shell: bash
+        run: |
+          # DinD runners set DOCKER_HOST=tcp://...:2376 (TLS) and expect certs
+          # at /certs/client/.  If the cert volume isn't mounted into job
+          # containers, docker commands fail.  Detect this and switch to the
+          # non-TLS port (2375) for the rest of the job.
+          echo "DOCKER_HOST=${DOCKER_HOST:-<unset>}"
+          echo "DOCKER_TLS_VERIFY=${DOCKER_TLS_VERIFY:-<unset>}"
+          echo "DOCKER_CERT_PATH=${DOCKER_CERT_PATH:-<unset>}"
+
+          if docker info >/dev/null 2>&1; then
+            echo "Docker daemon reachable with current settings"
+          elif [[ "${DOCKER_HOST:-}" == *":2376"* ]]; then
+            ALT_HOST="${DOCKER_HOST//:2376/:2375}"
+            echo "TLS connection failed — trying non-TLS fallback: ${ALT_HOST}"
+            export DOCKER_HOST="${ALT_HOST}"
+            unset DOCKER_TLS_VERIFY
+            unset DOCKER_CERT_PATH
+            if docker info >/dev/null 2>&1; then
+              echo "Connected via non-TLS port 2375"
+              # Persist for all subsequent steps
+              echo "DOCKER_HOST=${ALT_HOST}" >> "${GITHUB_ENV}"
+              echo "DOCKER_TLS_VERIFY=" >> "${GITHUB_ENV}"
+              echo "DOCKER_CERT_PATH=" >> "${GITHUB_ENV}"
+            else
+              echo "::error::Docker daemon unreachable on both :2376 (TLS) and :2375 (non-TLS)"
+              exit 1
+            fi
+          else
+            echo "::error::Docker daemon unreachable and DOCKER_HOST is not a DinD TCP endpoint"
+            docker info 2>&1 || true
+            exit 1
+          fi
+
       - name: Log in to Forgejo container registry
         env:
           GIT_TOKEN: ${{ github.token }}
diff --git a/deploy/scripts/build.sh b/deploy/scripts/build.sh
index b0cf733..3589e64 100755
--- a/deploy/scripts/build.sh
+++ b/deploy/scripts/build.sh
@@ -79,8 +79,28 @@ docker_preflight() {
   fi
 
   if ! docker info >/dev/null 2>&1; then
+    # --- DinD TLS fallback ---------------------------------------------------
+    # DinD runners set DOCKER_HOST=tcp://...:2376 (TLS) and expect certs at
+    # /certs/client/.  If the cert volume isn't mounted into job containers,
+    # docker info fails.  Try switching to the non-TLS port (2375) which DinD
+    # also exposes when DOCKER_TLS_CERTDIR is empty, or which some runners
+    # expose alongside the TLS port.
+    if [[ "${DOCKER_HOST:-}" == *":2376"* ]]; then
+      local alt_host="${DOCKER_HOST//:2376/:2375}"
+      log "TLS connection failed (certs likely missing); trying non-TLS fallback: ${alt_host}"
+      unset DOCKER_TLS_VERIFY 2>/dev/null || true
+      unset DOCKER_CERT_PATH 2>/dev/null || true
+      export DOCKER_HOST="${alt_host}"
+      if docker info >/dev/null 2>&1; then
+        log "Connected to Docker daemon via non-TLS fallback (${alt_host})"
+        return 0
+      fi
+      log "Non-TLS fallback also failed"
+    fi
+    # --- End DinD TLS fallback -----------------------------------------------
+
     if [[ "${runtime_context}" = "container" ]]; then
-      die "Docker daemon is unreachable from this container. Ensure /var/run/docker.sock is mounted with correct permissions, or run on host."
+      die "Docker daemon is unreachable from this container. Ensure /var/run/docker.sock is mounted with correct permissions, or set DOCKER_TLS_CERTDIR='' on the DinD sidecar to enable non-TLS connections on port 2375."
     fi
     die "Docker daemon is not reachable. Start Docker and retry."
   fi
