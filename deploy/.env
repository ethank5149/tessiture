# ------------------------------
# Unraid stack scope
# ------------------------------
# This stack deploys Tessiture only.
# Cloudflare Tunnel (cloudflared) is assumed to be managed externally/shared on your Unraid server.
# Point your existing tunnel ingress to this stack's Tessiture service target per README guidance.

# ------------------------------
# Image tags
# ------------------------------
# Build/push this image from this repository, then reference it here.
# The helper scripts can auto-bump this value using semantic versioning:
#   deploy/scripts/build.sh --env-file deploy/.env --version-bump auto
#   deploy/scripts/one-shot.sh --env-file deploy/.env --version-bump auto
# Default behavior:
#   - auto => major if any commit contains BREAKING CHANGE or uses ! convention
#   - auto => minor if commit subjects include feat(...):, otherwise patch
#   - major bump is also available manually: --version-bump major
# Helpers update TESSITURE_IMAGE in the env file after each versioned build.
TESSITURE_IMAGE=tessiture:0.1.2

# ------------------------------
# Tessiture runtime
# ------------------------------
TESSITURE_ENV=production
TESSITURE_HOST=0.0.0.0
TESSITURE_PORT=8000

# ------------------------------
# Data paths in container
# ------------------------------
TESSITURE_UPLOAD_DIR=/data/uploads
TESSITURE_OUTPUT_DIR=/data/outputs
TESSITURE_EXAMPLES_DIR=/app/examples/tracks
TESSITURE_EXAMPLES_HOST_PATH=/mnt/user/public/tessiture/examples/tracks

# ------------------------------
# Data paths on Unraid host (persistent)
# ------------------------------
TESSITURE_UPLOAD_HOST_PATH=/mnt/user/appdata/tessiture/uploads
TESSITURE_OUTPUT_HOST_PATH=/mnt/user/appdata/tessiture/outputs
TESSITURE_JOBS_HOST_PATH=/mnt/user/appdata/tessiture/jobs
TESSITURE_LOG_HOST_PATH=/mnt/user/appdata/tessiture/logs

# ------------------------------
# Job and global log paths in container
# ------------------------------
TESSITURE_JOBS_DIR=/tmp/tessiture_jobs
TESSITURE_LOG_DIR=/tmp/tessiture_logs

# ------------------------------
# Request/abuse limits
# ------------------------------
TESSITURE_UPLOAD_MAX_BYTES=26214400
TESSITURE_RATE_LIMIT_CAPACITY=10
TESSITURE_RATE_LIMIT_REFILL_PER_SEC=0.5

# ------------------------------
# Public hostname used by Caddy's Tessiture site block (:8080 host-based route)
# Cloudflare Tunnel should route this hostname to Caddy (caddy:8080 preferred, host:5080 fallback).
# Must match the hostname configured in your Caddyfile and DNS.
# ------------------------------
TESSITURE_PUBLIC_HOSTNAME=tess.indecisivephysicist.space

# ------------------------------
# CORS
# Use your public app origin(s), comma-separated.
# Example: https://voice.example.com,https://admin.example.com
# ------------------------------
TESSITURE_CORS_ORIGINS=https://tess.indecisivephysicist.space

# ------------------------------
# Authentik preconfiguration (disabled by default; safe placeholders)
# Set *_ENABLED=true only when corresponding Caddy scaffolding is uncommented.
# ------------------------------
AUTHENTIK_FORWARD_AUTH_ENABLED=false
AUTHENTIK_OUTPOST_ROUTE_ENABLED=false
AUTHENTIK_DOMAIN=auth.example.com
AUTHENTIK_OUTPOST_URL=http://authentik-proxy:9000
AUTHENTIK_FORWARD_AUTH_URI=/outpost.goauthentik.io/auth/caddy
AUTHENTIK_OUTPOST_PATH_PREFIX=/outpost.goauthentik.io

# ------------------------------
# Vocal separation
# ------------------------------
TESSITURE_VOCAL_SEPARATION=auto
TESSITURE_STEM_CACHE_HOST_PATH=/mnt/user/appdata/tessiture/stem_cache

# ------------------------------
# Optional LAN debug only (when enabling ports: in compose)
# ------------------------------
TESSITURE_LAN_BIND_PORT=8766
TESSITURE_RELEASE_VERSION=0.1.2
