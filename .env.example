# --- Runtime ---
TESSITURE_ENV=production
TESSITURE_HOST=0.0.0.0
TESSITURE_PORT=8000

# --- File system paths (bind mount these on Unraid) ---
TESSITURE_UPLOAD_DIR=/data/uploads
TESSITURE_OUTPUT_DIR=/data/outputs

# --- Upload validation ---
TESSITURE_UPLOAD_MAX_BYTES=26214400
TESSITURE_UPLOAD_EXTENSIONS=.wav,.mp3,.flac,.m4a,.opus
TESSITURE_UPLOAD_MIME_TYPES=audio/wav,audio/x-wav,audio/mpeg,audio/flac,audio/x-flac,audio/mp4,audio/opus,audio/x-opus,audio/ogg,application/ogg

# --- API behavior ---
TESSITURE_RATE_LIMIT_CAPACITY=10
TESSITURE_RATE_LIMIT_REFILL_PER_SEC=0.5
TESSITURE_CORS_ORIGINS=http://localhost,http://127.0.0.1

# --- Frontend to API wiring ---
VITE_API_BASE_URL=
